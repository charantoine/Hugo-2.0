# POC Hugo — copy to .env and set values (do not commit .env)

# Database (required for docker-compose)
POSTGRES_DB=hugo_poc
POSTGRES_USER=hugo
POSTGRES_PASSWORD=changeme

# Django
SECRET_KEY=changeme-in-production
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,api
# Production: use config.settings.production
# DJANGO_SETTINGS_MODULE=config.settings.production
# CORS: origins séparés par des virgules (frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: DATABASE_URL overrides compose-built URL if set
# DATABASE_URL=postgresql://hugo:changeme@postgres:5432/hugo_poc

# MinIO (docker) — API uses these to write evidence/exports
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=hugo-poc
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY default to MINIO_ROOT_* in compose

# Celery
# CELERY_BROKER_URL=redis://redis:6379/0

# LLM (Ollama in container)
# LLM_BASE_URL=http://llm:11434
# LLM_MODEL=mistral

# Ports (host) — 8080 évite conflits avec port 80 (IIS, etc.)
HTTP_PORT=8080
HTTPS_PORT=443
